# Copy to .env and fill in. Never commit .env.

# Claude — extraction + email drafting
ANTHROPIC_API_KEY=sk-ant-...

# n8n Gmail-send webhook (n8n owns the Gmail OAuth). Can be the same workflow
# the web app uses. The agent POSTs { to, toName, from, subject, body }.
N8N_EMAIL_SEND_URL=
# Shared secret sent as the `x-webhook-secret` header; verify it inside n8n.
N8N_WEBHOOK_SECRET=

# Gmail address / alias to send from (passed to n8n as `from`).
GMAIL_SEND_AS=you@example.com
# Name used to sign emails and as the drafting persona.
SENDER_NAME=Brant

# Run mode: "draft" (default, unattended, writes review report, sends nothing)
# or "send" (interactive, asks y/n per email, BCCs guessed variants).
RUN_MODE=draft
# Optional hard cap on how many emails a single `send` run may deliver.
SEND_CAP=

# Web search for finding people + company domains (name -> email guessing).
# Tavily is recommended (purpose-built, free tier at tavily.com). If only
# OPENAI_API_KEY is set, the OpenAI web_search tool is used instead.
TAVILY_API_KEY=
OPENAI_API_KEY=

# Eventbrite — optional. If absent, discovery falls back to web search.
EVENTBRITE_API_KEY=

# Contact enrichment — optional fallback if site scraping fails.
HUNTER_API_KEY=

# Outreach filters (comma-separated for lists)
OUTREACH_INDUSTRIES=SaaS,DevTools,Fintech
OUTREACH_DATE_FROM=2026-08-01
OUTREACH_DATE_TO=2026-12-31
OUTREACH_REGIONS=US,UK

# Paths (defaults are fine)
SENT_LOG_PATH=./sent-log.sqlite

# HQ bridge (same Supabase as the web app)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
